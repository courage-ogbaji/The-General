# --- Database ---
# PostgreSQL connection string. For local dev you can run a local Postgres via
# `npx prisma dev` (see README) or Docker. For production use a hosted provider
# such as Neon, Supabase, or Railway.
DATABASE_URL="postgresql://user:password@localhost:5432/the_general?sslmode=disable"

# --- Auth (NextAuth.js / Auth.js v5) ---
# Generate with: npx auth secret
AUTH_SECRET="replace-with-a-long-random-string"
# Base URL of the deployed app (used for callback URLs in production).
NEXTAUTH_URL="http://localhost:3000"

# Optional Google OAuth login. Leave unset to disable the Google sign-in button.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Cloudinary (image/video uploads) ---
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Public cloud name, exposed to the browser for next-cloudinary display components.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
# Unsigned upload preset used by the client-side upload widget.
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=""

# --- Celebrant seed account ---
# Used by `npm run db:seed` to create/promote the one CELEBRANT account.
CELEBRANT_EMAIL="celebrant@example.com"
CELEBRANT_PASSWORD="change-me-before-seeding"
CELEBRANT_NAME="The Celebrant"
